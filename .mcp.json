{
  "mcpServers": {
    "semantic-scholar": {
      "type": "stdio",
      "command": "zsh",
      "args": ["-lc", "set -a; [ -f .env ] && source .env; set +a; exec uvx semantic-scholar-fastmcp"]
    },
    "paper-search": {
      "type": "stdio",
      "command": "uvx",
      "args": ["paper-search-mcp"]
    },
    "fetch": {
      "type": "stdio",
      "command": "uvx",
      "args": ["mcp-server-fetch"]
    }
  }
}
